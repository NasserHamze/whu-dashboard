# Servidor — coletor WHU (nunca commitar .env real)
PORT=3000
NODE_ENV=development

# Segredo para n8n chamar POST /api/collect
COLLECTOR_SECRET=change-me-in-production

# Supabase — backend usa service role (grava logs e métricas)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# API WHU (padrão do export original)
WHU_BASE_URL=https://api.wescctech.com.br/core/v2/api

# Canais: JSON { "Nome do canal": "token_access", ... }
WHU_CHANNELS_JSON={"EXEMPLO_CANAL":"seu_token_aqui"}

# Opcional: delays em ms entre chamadas
# WHU_REQUEST_DELAY_MS=80
# WHU_DETAIL_DELAY_MS=50

# --- Frontend (Vite) — copie também para o .env na raiz do projeto ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
# Use a chave anon + RLS no Supabase; não use service role no browser.
VITE_SUPABASE_ANON_KEY=
